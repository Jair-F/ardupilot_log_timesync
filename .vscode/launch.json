{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "logs/good/00000001.BIN",
                "logs/good/2026-07-11 16-36-09.tlog",
                "./logs/good/log.mcap"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}
